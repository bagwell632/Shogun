# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_channel_id_here

# GitHub
GITHUB_TOKEN=your_github_token_here
GITHUB_REPOSITORY=owner/repo

# Paths
VIDEO_PATH=./videos
DATA_PATH=./data

# Bot Configuration
BOT_ENABLED=true
AUTO_MODERATE=true
AUTO_UPLOAD=false
AUTO_SCHEDULE=false

# Monetization
MONETIZATION_TRACK=true
REPORT_FREQUENCY=daily
